{
  "name": "node-mysql",
  "description": "MySQL client using raw TCP (node:net) with ES6 tagged templates and SQL injection protection",
  "version": "0.0.0",
  "keywords": [
    "mysql",
    "sql",
    "tagged-template",
    "tcp"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "tsc-alias -f -p tsconfig.build.json && tsc -p tsconfig.build.json --removeComments false --declaration --emitDeclarationOnly --outDir dist/types",
    "lint": "eslint . --cache",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:watchAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@jest/globals": "^30.3.0",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || ^24.11.0"
  },
  "author": {
    "name": "Luciano Alves",
    "url": "https://github.com/luas10c"
  },
  "homepage": "https://github.com/luas10c/tsnite",
  "repository": {
    "type": "github",
    "url": "git+https://github.com/luas10c/tsnite.git"
  },
  "bugs": {
    "url": "https://gitbub.com/luas10c/tsnite/issues"
  },
  "license": "UNLICENSED"
}
